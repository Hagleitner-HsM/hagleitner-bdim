{
    "$id": "https://schema.hagleitner.com/bdim/2026-06-01/customer.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Customer",
    "type": "object",
    "unevaluatedProperties": false,
    "required": [
        "id",
        "name1",
        "status",
        "customerRelations",
        "contentHash"
    ],
    "properties": {
        "id": {
            "$ref": "../components/basetypes.schema.json#/$defs/uuid"
        },
        "erpId": {
            "type": "string",
            "pattern": "^[A-Z0-9]{1,20}$"
        },
        "name1": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 100
        },
        "name2": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 50
        },
        "name3": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 30
        },
        "phoneNumber1": {
            "$ref": "../components/basetypes.schema.json#/$defs/phoneE164",
            "description": "Phone number 1"
        },
        "phoneNumber2": {
            "$ref": "../components/basetypes.schema.json#/$defs/phoneE164",
            "description": "Phone number 2"
        },
        "emailAddresses": {
            "type": "object",
            "properties": {
                "primary": { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "orderConfirmation":   { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "invoice": { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "invoiceCc": { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "paymentReminder": { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "paymentReminderCc": { "$ref": "../components/basetypes.schema.json#/$defs/email"},
                "shippingAdvice": { "$ref": "../components/basetypes.schema.json#/$defs/email"}
            },
            "unevaluatedProperties": false,
            "minProperties": 1
        },        
        "lifeCycleStatus": {
            "type": "string",
            "enum": ["active", "deleted"],
            "description": "The status of the customer"
        },
        "languageTag": {
            "type": "string",
            "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z]{2}|\\-[A-Za-z]{4})?$",
            "description": "A BCP 47 language tag that identifies the language context, often including region or script. The locale tag is used as the key for resolving a locale or culture with concrete formatting conventions."
        },
        "timezone": {
            "type": "string",
            "pattern": "^[A-Za-z]+/[A-Za-z_]+(?:/[A-Za-z_]+)?$",
            "description": "The IANA time zone identifier representing the customer's time zone, such as 'America/New_York' or 'Europe/Berlin'."
        },
        "avatar": {
            "type": "string",
            "format": "uri",
            "description": "URL to the customer's avatar image."
        },
        "vatId": {
            "type": "string",
            "pattern": "^[A-Z]{2}[A-Z0-9]+$",
            "description": "The customer's VAT identification number, starting with a two-letter country code followed by alphanumeric characters."
        },  
        "roles": {
            "type": "array",
            "items": { "type": "string", "enum": ["reseller", "invoiceRecipient", "hierarchyParent", "responsibilityCenter", "conditionOwner"] },
            "uniqueItems": true,
            "description": "Roles assigned to the customer",
            "minItems": 1
        },
        "customerRelations": {
            "type": "object",
            "unevaluatedProperties": false,
            "required": [
                "reseller"
            ],
            "properties": {
                "reseller": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": {
                            "oneOf": [
                                { "$ref": "../components/basetypes.schema.json#/$defs/uuid" },
                                { "type": "null" }
                            ]
                        },
                        "erpTenantId": {
                            "$ref": "../components/basetypes.schema.json#/$defs/uuid"
                        }
                    }
                },
                "invoice": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": { "$ref": "../components/basetypes.schema.json#/$defs/uuid" }
                    }
                },
                "condition": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": { "$ref": "../components/basetypes.schema.json#/$defs/uuid" }
                    }
                },
                "hierarchy": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": { "$ref": "../components/basetypes.schema.json#/$defs/uuid" }
                    }
                }
            }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 date-time when the customer was first created in the owning system."
        },
        "contentHash": {
            "$ref": "../components/basetypes.schema.json#/$defs/contentHash"
        }
    },
    "dependentRequired": {
        "name2": [
            "name1"
        ],
        "name3": [
            "name2",
            "name1"
        ]
    },
    "allOf": [
        {
            "$ref": "../components/address.schema.json"
        }
    ]
}