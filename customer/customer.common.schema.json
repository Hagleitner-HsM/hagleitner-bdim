{
    "$id": "https://schema.hagleitner.com/bdim/2026-06-01/customer.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Customer",
    "type": "object",
    "unevaluatedProperties": false,
    "required": [
        "id",
        "name1",
        "status",
        "customerRelations",
        "contentHash"
    ],
    "properties": {
        "id": {
            "$ref": "../components/basetypes.schema.json#/$defs/uuid"
        },
        "name1": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 100
        },
        "name2": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 50
        },
        "name3": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 30
        },
        "phoneNumber1": {
            "$ref": "../components/basetypes.schema.json#/$defs/phoneE164",
            "description": "Phone number 1"
        },
        "phoneNumber2": {
            "$ref": "../components/basetypes.schema.json#/$defs/phoneE164",
            "description": "Phone number 2"
        },
        "roles": {
            "type": "array",
            "items": { "type": "string", "enum": ["reseller", "invoiceRecipient", "hierarchyParent", "responsibilityCenter", "conditionOwner"] },
            "uniqueItems": true,
            "description": "Roles assigned to the customer",
            "minItems": 1
        },
        "customerRelations": {
            "type": "object",
            "unevaluatedProperties": false,
            "required": [
                "reseller"
            ],
            "properties": {
                "reseller": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": {
                            "oneOf": [
                                { "$ref": "../components/basetypes.schema.json#/$defs/uuid" },
                                { "type": "null" }
                            ]
                        }
                    }
                },
                "invoice": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": { "$ref": "../components/basetypes.schema.json#/$defs/uuid" }
                    }
                },
                "condition": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": { "$ref": "../components/basetypes.schema.json#/$defs/uuid" }
                    }
                },
                "hierarchy": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "required": ["anchestorCustomerId"],
                    "properties": {
                        "anchestorCustomerId": { "$ref": "../components/basetypes.schema.json#/$defs/uuid" }
                    }
                }
            }
        },
        "status": {
            "type": "string",
            "enum": ["active", "inactive", "suspended"],
            "description": "The status of the customer. Active customers are regular customers that can place orders. Inactive customers are customers that have been deactivated and cannot place orders. Suspended customers are customers that have been temporarily suspended and cannot place orders. The status of a customer can be changed, but a customer cannot be deleted. Instead, it can be marked as inactive."
        },
        "emailAddresses": {
            "type": "object",
            "properties": {
                "work":      { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "private":   { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "invoicing": { "$ref": "../components/basetypes.schema.json#/$defs/email" },
                "other":     { "$ref": "../components/basetypes.schema.json#/$defs/email" }
            },
            "unevaluatedProperties": false,
            "minProperties": 1
        },
        "contentHash": {
            "$ref": "../components/basetypes.schema.json#/$defs/contentHash"
        }
    },
    "dependentRequired": {
        "name2": [
            "name1"
        ],
        "name3": [
            "name2",
            "name1"
        ]
    },
    "allOf": [
        {
            "$ref": "../components/address.schema.json"
        }
    ]
}