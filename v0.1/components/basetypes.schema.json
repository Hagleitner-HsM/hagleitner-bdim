{
    "$id": "https://schema.hagleitner.com/bdim/v0.1/basetypes.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "x-revision": "2026-05-11",
    "description": "Address",
    "type": "object",
    "$defs": {
        "singleLineText": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\u0000-\\u001F\\u007F\\s](?:[^\\u0000-\\u001F\\u007F]*[^\\u0000-\\u001F\\u007F\\s])?$"
        },
        "singleLineTextOrNull": {
            "type": [
                "string",
                "null"
            ],
            "minLength": 1,
            "pattern": "^[^\\u0000-\\u001F\\u007F\\s](?:[^\\u0000-\\u001F\\u007F]*[^\\u0000-\\u001F\\u007F\\s])?$"
        },
        "uuid": {
            "type": "string",
            "format": "uuid",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
        },
        "phoneE164OrNull": {
            "type": [
                "string",
                "null"
            ],
            "description": "Phone number formatted as E.164",
            "pattern": "^\\+[1-9]\\d{1,14}$"
        },
        "emailOrNull": {
            "type": [
                "string",
                "null"
            ],
            "format": "email"
        },
        "uuidOrNull": {
            "anyOf": [
                { "$ref": "#/$defs/uuid" },
                { "type": "null" }
            ],
            "description": "UUID or null."
        },
        "contentHash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64,
            "pattern": "^[a-f0-9]{64}$",
            "description": "Cryptographic hash of the object's canonical content, excluding the contentHash property itself."
        },
        "languageTag": {
            "type": "string",
            "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z]{2}|\\-[A-Za-z]{4})?$",
            "description": "A BCP 47 language tag that identifies the language context, often including region or script. The languag tag is used as the key for resolving a locale or culture with concrete formatting conventions."
        },
        "code": {
            "type": "string",
            "pattern": "^[A-Z0-9]+$"
        },
        "geoLocation": {
            "type": [
                "object",
                "null"
            ],
            "required": [
                "latitude",
                "longitude"
            ],
            "unevaluatedProperties": false,
            "properties": {
                "latitude": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                },
                "longitude": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                },
                "elevation": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Elevation in meters above the WGS84 ellipsoid (EPSG:4326)."
                }
            },
            "description": "Geographic coordinates (WGS84, EPSG:4326).",
            "dependentRequired": {
                "latitude": [
                    "longitude"
                ],
                "longitude": [
                    "latitude"
                ]
            }
        },
        "localizedText": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "languageTag": {
                        "$ref": "#/$defs/languageTag"
                    },
                    "text": {
                        "$ref": "#/$defs/singleLineText"
                    }
                },
                "required": [
                    "languageTag",
                    "text"
                ],
                "unevaluatedProperties": false
            },
            "minItems": 1,
            "description": "An array of translations for a given text property, where each translation includes a language tag and the corresponding translated text."
        }
    }
}