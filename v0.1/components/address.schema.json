{
    "$id": "https://schema.hagleitner.com/bdim/v0.1/address.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "x-revision": "2026-05-11",
    "description": "General schema for postal addresses",
    "type": "object",
    "required": [
        "city",
        "countryCode"
    ],
    "properties": {
        "address1": {
            "$ref": "baseTypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 100,
            "x-status": "approved"
        },
        "address2": {
            "$ref": "baseTypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 50,
            "x-status": "approved"
        },
        "postalCode": {
            "$ref": "baseTypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 20,
            "x-status": "needsDiscussion"
        },
        "city": {
            "$ref": "baseTypes.schema.json#/$defs/singleLineText",
            "maxLength": 30,
            "x-status": "needsDiscussion"
        },
        "stateOrProvince": {
            "$ref": "baseTypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 30,
            "x-status": "approved"
        },
        "countryCode": {
            "type": "string",
            "pattern": "^[A-Z]{2}$",
            "description": "A valid ISO 3166-1 alpha-2 country code",
            "x-status": "approved"
        },
        "geoLocation": {
            "$ref": "baseTypes.schema.json#/$defs/geoLocation",
            "x-status": "approved"
         }
    },
    "dependentRequired": {
        "address2": [
            "address1"
        ]
    }
}