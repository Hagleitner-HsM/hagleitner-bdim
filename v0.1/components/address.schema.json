{
    "$id": "https://schema.hagleitner.com/bdim/2026-06-01/address.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Address",
    "type": "object",
    "required": [
        "city",
        "countryCode"
    ],
    "properties": {
        "address1": {
            "$ref": "basetypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 100,
            "x-status": "approved"
        },
        "address2": {
            "$ref": "basetypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 50,
            "x-status": "approved"
        },
        "postalCode": {
            "$ref": "basetypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 20,
            "x-status": "approved"
        },
        "city": {
            "$ref": "basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 30,
            "x-status": "approved"
        },
        "stateOrProvince": {
            "$ref": "basetypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 30,
            "x-status": "approved"
        },
        "countryCode": {
            "type": "string",
            "pattern": "^[A-Z]{2}$",
            "description": "A valid ISO 3166-1 alpha-2 country code"            ,
            "x-status": "approved"
        },
        "geoLocation": {
            "$ref": "basetypes.schema.json#/$defs/geoLocation",
            "x-status": "approved"
         }
    },
    "dependentRequired": {
        "latitude": [
            "longitude"
        ],
        "longitude": [
            "latitude"
        ],
        "address2": [
            "address1"
        ]
    }
}