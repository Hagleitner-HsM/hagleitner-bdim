{
    "$id": "https://schema.hagleitner.com/bdim/v0.1/customer.erp.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "x-revision": "2026-05-11",
    "description": "Schema for the ERP-owned customer attribute partition",
    "type": "object",
    "required": [
        "erpCustomerNumber"
    ],
    "properties": {
        "erpCustomerNumber": {
            "type": [
                "string"
            ],
            "pattern": "^[A-Z0-9\\-_]{1,20}$",
            "description": "Customer number uniquely identifies a customer within a reseller's customer base."
        }
    }
}