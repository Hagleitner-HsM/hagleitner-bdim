{
    "$id": "https://schema.hagleitner.com/bdim/2026-06-01/customer.common.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "This it the schema for common customer properties that are shared accoss different sytems. Entities of this schema can be owned by different source systems.",
    "type": "object",
    "required": [
        "id",
        "name1",
        "statusCode",
        "customerRelations",
        "languageTag",
        "createdAt",
        "contentHash"
    ],
    "properties": {
        "id": {
            "$ref": "../components/basetypes.schema.json#/$defs/uuid",
            "description": "UUID uniquely identifying the customer.",
            "x-status": "approved"
        },
        "owningSystem": {
            "type": "string",
            "enum": [
                "CRM",
                "ERP"
            ],
            "description": "The system that owns the customer record. Only the owning system is allowed to set and update the content of the customer record, other systems can only read the record and may not update it. The owning system is responsible for setting the contentHash property based on the content of the customer record.",
            "x-status": "needDiscussion"
        },
        "erpTenantId": {
            "$ref": "../components/basetypes.schema.json#/$defs/uuid",
            "description": "UUID of the ERP tenant associated with this customer. This Id must be set by the owning system."
        },
        "name1": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineText",
            "maxLength": 100,
            "description": "Primary customer name line.",
            "x-status": "approved"
        },
        "name2": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 50,
            "description": "Secondary customer name line.",
            "x-status": "approved"
        },
        "name3": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 30,
            "description": "Tertiary customer name line.",
            "x-status": "approved"
        },
        "phoneNumber1": {
            "$ref": "../components/basetypes.schema.json#/$defs/phoneE164OrNull",
            "description": "Phone number 1",
            "x-status": "approved"
        },
        "phoneNumber2": {
            "$ref": "../components/basetypes.schema.json#/$defs/phoneE164OrNull",
            "description": "Phone number 2",
            "x-status": "approved"
        },
        "emailAddresses": {
            "type": "object",
            "description": "Email addresses with defined semantics for different communication purposes.",
            "properties": {
                "primary": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "Primary email address of the customer."
                },
                "orderConfirmation": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "Email address for order confirmations."
                },
                "invoice": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "Email address for invoices."
                },
                "invoiceCc": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "CC email address for invoices."
                },
                "paymentReminder": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "Email address for payment reminders."
                },
                "paymentReminderCc": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "CC email address for payment reminders."
                },
                "shippingAdvice": {
                    "$ref": "../components/basetypes.schema.json#/$defs/emailOrNull",
                    "description": "Email address for shipping advice notifications."
                }
            },
            "unevaluatedProperties": false,
            "x-status": "needDiscussion"
        },
        "statusCode": {
            "type": "string",
            "enum": [
                "active",
                "inactive"
            ],
            "description": "The status of the customer",
            "default": "active",
            "x-status": "approved"
        },
        "statusCodeReason": {
            "type": "string",
            "enum": [
                "",
                ""
            ],
            "description": "The status of the customer",
            "default": "active",
            "x-status": "approved"
        },
        "blockedFor": {
            "type": "string",
            "enum": [
                "none",
                "shipping",
                "invoicing",
                "all"
            ],
            "default": "none",
            "x-status": "approved"
        },
        "blockedForReasonId": {
            "type": "string",
            "format": "uuid",
            "x-status": "needDiscussion"
        },
        "languageTag": {
            "$ref": "../components/basetypes.schema.json#/$defs/languageTag",
            "description": "A BCP 47 language tag that identifies the language context, often including region or script. The languag tag is used as the key for resolving a locale or culture with concrete formatting conventions.",
            "x-status": "approved"
        },
        "timezone": {
            "type": "string",
            "pattern": "^[A-Za-z]+/[A-Za-z_]+(?:/[A-Za-z_]+)?$",
            "description": "The IANA time zone identifier representing the customer's time zone, such as 'America/New_York' or 'Europe/Berlin'.",
            "default": "Etc/UTC",
            "x-status": "approved"
        },
        "taxIdentificationNumber": {
            "$ref": "../components/basetypes.schema.json#/$defs/singleLineTextOrNull",
            "description": "The customer's VAT identification number, starting with a two-letter country code followed by alphanumeric characters.",
            "x-status": "approved"
        },
        "roles": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "reseller"
                ]
            },
            "uniqueItems": true,
            "description": "Roles assigned to the customer",
            "x-status": "needDiscussion",
            "minItems": 1
        },
        "customerRelations": {
            "type": "object",
            "description": "Defines the customer's relationships to other customers.",
            "unevaluatedProperties": false,
            "required": [
                "reseller"
            ],
            "properties": {
                "reseller": {
                    "type": "object",
                    "description": "Reseller relationship",
                    "unevaluatedProperties": false,
                    "required": [
                        "ancestorCustomerId"
                    ],
                    "properties": {
                        "ancestorCustomerId": {
                            "$ref": "../components/basetypes.schema.json#/$defs/uuidOrNull",
                            "description": "UUID of the ancestor reseller customer, null only for the root customer."
                        }
                    }
                },
                "invoiceRecipient": {
                    "type": "object",
                    "description": "Invoicing relationship",
                    "unevaluatedProperties": false,
                    "required": [
                        "ancestorCustomerId"
                    ],
                    "properties": {
                        "ancestorCustomerId": {
                            "$ref": "../components/basetypes.schema.json#/$defs/uuidOrNull",
                            "description": "UUID of the ancestor invoice recipient customer."
                        }
                    }
                },
                "conditionOwner": {
                    "type": "object",
                    "description": "Condition relationship",
                    "unevaluatedProperties": false,
                    "required": [
                        "ancestorCustomerId"
                    ],
                    "properties": {
                        "ancestorCustomerId": {
                            "$ref": "../components/basetypes.schema.json#/$defs/uuidOrNull",
                            "description": "UUID of the ancestor condition owner customer."
                        }
                    }
                },
                "parent": {
                    "type": "object",
                    "description": "Hierarchy relationship",
                    "unevaluatedProperties": false,
                    "required": [
                        "ancestorCustomerId"
                    ],
                    "properties": {
                        "ancestorCustomerId": {
                            "$ref": "../components/basetypes.schema.json#/$defs/uuidOrNull",
                            "description": "UUID of the ancestor hierarchy parent customer."
                        }
                    }
                }
            }
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "RFC 3339 date-time when the customer was first created in the owning system.",
            "x-status": "approved"
        },
        "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "RFC 3339 date-time when the customer was last updated in the owning system.",
            "x-status": "approved"
        }
    },
    "allOf": [
        {
            "$ref": "../components/address.schema.json"
        },
        {
            "if": {
                "properties": {
                    "blockedFor": {
                        "enum": [
                            "shipping",
                            "invoicing",
                            "all"
                        ]
                    }
                },
                "required": [
                    "blockedFor"
                ]
            },
            "then": {
                "required": [
                    "blockedForReasonId"
                ]
            }
        },   
        {
            "if": {
                "properties": {
                    "statusCode": {
                        "enum": ["inactive"]
                    }
                },
                "required": [
                    "statusCode"
                ]
            },
            "then": {
                "required": [
                    "statusCodeReason"
                ]
            }
        }          
    ],
    "dependentRequired": {
        "name2": [
            "name1"
        ],
        "blockedForReasonId": [
            "blockedFor"
        ]
    }   
}