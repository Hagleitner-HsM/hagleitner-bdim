{
    "$id": "https://schema.hagleitner.com/bdim/v0.1/customer.crm.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "x-revision": "2026-05-11",
    "description": "Schema for the CRM-owned customer attribute partition",
    "type": "object",
    "required": [
        "crmCustomerNumber"
    ],
    "properties": {
        "crmCustomerNumber": {
            "type": ["string"],
            "pattern": "^[ABDEFGHJKMNPQRSTUVWXY][0-9]{1,6}$",
            "description": "Customer number uniquely identifies a customer within a reseller's customer base.",
            "x-status": "approved"
        }
    }
}