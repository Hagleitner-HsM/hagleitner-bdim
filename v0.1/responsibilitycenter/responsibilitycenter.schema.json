{
    "$id": "https://schema.hagleitner.com/bdim/v0.1/responsibilityCenter.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "x-revision": "2026-05-12",
    "type": "object",
    "unevaluatedProperties": false, 
    "required": [
        "id",
        "code",
        "name1"
    ],
    "properties": {
        "id": {
            "$ref": "../components/baseTypes.schema.json#/$defs/uuid",
            "description": "The unique identifier for the responsibility center.",
            "x-status": "approved"
        },
        "code": {
            "$ref": "../components/baseTypes.schema.json#/$defs/code",
            "maxLength": 20,
            "description": "The unique code for the responsibility center.",
            "x-status": "approved"
        },
        "costCenter": {
            "$ref": "../components/baseTypes.schema.json#/$defs/code",
            "maxLength": 20,
            "description": "The unique code of the cost center that the responsibility center belongs to.",
            "x-status": "approved"
        },
        "warehouseLocation":{
            "$ref": "../components/baseTypes.schema.json#/$defs/code",
            "maxLength": 10,
            "description": "The code of the warehouse associated with the responsibility center.",
            "x-status": "approved"
        },
        "name1": {
            "$ref": "../components/baseTypes.schema.json#/$defs/singleLineText",
            "maxLength": 50,
            "description": "The name of the responsibility center.",
            "x-status": "approved"
        },
        "name2": {
            "$ref": "../components/baseTypes.schema.json#/$defs/singleLineTextOrNull",
            "maxLength": 50,
            "description": "The name of the responsibility center.",
            "x-status": "approved"
        },
        "phoneNumber":{
            "$ref": "../components/baseTypes.schema.json#/$defs/phoneE164OrNull",
            "description": "Phone number of the responsibility center.",
            "x-status": "approved"
        },
        "emailAddress":{
            "$ref": "../components/baseTypes.schema.json#/$defs/emailOrNull",
            "description": "Email address of the responsibility center.",
            "x-status": "approved"
        } ,
        "logisticsManagerId":{
            "$ref": "../components/baseTypes.schema.json#/$defs/uuidOrNull",
            "description": "The ID of the logistics manager.",
            "x-status": "approved"
        },
        "organizationManagerId":{
            "$ref": "../components/baseTypes.schema.json#/$defs/uuidOrNull",
            "description": "The ID of the organization manager.",
            "x-status": "approved"
        }        
    },
    "allOf": [
        {
            "$ref": "../components/address.schema.json"
        }
    ]

    
}